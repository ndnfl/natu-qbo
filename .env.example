# Intuit Developer app credentials
# Create at https://developer.intuit.com/app/developer/myapps -> your app -> Keys & credentials -> Production
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# OAuth redirect URI (must match exactly what is registered in the Intuit app).
# - For sandbox / dev keys, http://localhost:8765/callback works directly.
# - For production keys, Intuit requires HTTPS. Use the GitHub Pages bouncer URL:
#     https://<your-github-username>.github.io/natu-qbo/
#   (the page in docs/index.html forwards the OAuth code back to your localhost).
QBO_REDIRECT_URI=http://localhost:8765/callback

# Port the local callback server binds to (only used when QBO_REDIRECT_URI is not localhost).
QBO_LOCAL_CALLBACK_PORT=8765

# "production" or "sandbox"
QBO_ENV=production
